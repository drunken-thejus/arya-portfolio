# ── Database ─────────────────────────────────────────────────────
# Leave DATABASE_URL UNSET for local development — the app falls back to a
# local SQLite file (dev.db) so you can run everything with zero cloud setup.
#
# For production, uncomment and paste the Supabase "Connection string" → "URI"
# from Project Settings → Database. The scheme must be postgresql:// (not
# postgres://) — the backend will also normalise it automatically.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── JWT auth ─────────────────────────────────────────────────────
# Generate a strong secret:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720
ALGORITHM=HS256

# ── First admin user (created by `python seed.py`) ───────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Site Owner

# ── Supabase Storage ─────────────────────────────────────────────
# Leave these UNSET for local dev — uploads are saved to backend/uploads/ and
# served at /uploads/... For production, uncomment and fill in.
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use the SERVICE ROLE key (server-side only — never expose to the frontend)
# SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=portfolio-media

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Vercel domain + localhost)
CORS_ORIGINS=http://localhost:3000,https://your-portfolio.vercel.app
